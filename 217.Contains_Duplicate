class Solution {
public:
    bool containsDuplicate(vector<int>& nums) {
        //sort input
        sort(nums.begin(), nums.end());

        //traverse array and return true when duplicate found
        for(int i = 0; i < nums.size() - 1; i++){
            if(nums[i] == nums[i + 1])
                return true;
        }
        return false;
    }
};
